# ─── APP Laravel ───────────────────────────────────────────────────────────────
APP_KEY=                        # php artisan key:generate --show
APP_ENV=production

# ─── API Python ────────────────────────────────────────────────────────────────
API_KEY=                        # python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=                     # python3 -c "import secrets; print(secrets.token_hex(32))"
UPLOAD_TOKEN=                   # python3 -c "import secrets; print(secrets.token_urlsafe(16))"

# ─── Anthropic (para el Classifier con IA) ─────────────────────────────────────
ANTHROPIC_API_KEY=              # Tu API key de Anthropic

# ─── Base de datos ─────────────────────────────────────────────────────────────
DB_ROOT_PASS=                   # Contraseña root MySQL (solo para el contenedor)
DB_NAME=kraftdo
DB_USER=kraftdo
DB_PASS=                        # Contraseña del usuario kraftdo

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── SMTP (correos automáticos) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                      # tu@gmail.com
SMTP_PASS=                      # App Password de Gmail → myaccount.google.com/apppasswords

# ─── Destinatarios de reportes ─────────────────────────────────────────────────
EMAIL_ADILLE=jonathan@adille.cl
EMAIL_EXTRACTORES=jonathan@extractoreschile.cl

# ─── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASS=                       # Contraseña para el panel de n8n
N8N_KEY=                        # python3 -c "import secrets; print(secrets.token_hex(32))"

# ─── Google Sheets (opcional) ──────────────────────────────────────────────────
SHEETS_ID=                        # ID de tu Google Sheet
# GOOGLE_CREDS_PATH=/app/creds.json   # descomentar cuando tengas el creds.json

# ─── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60

# ─── Bases de datos separadas por empresa ──────────────────────────────────────
# Por defecto usan el mismo usuario/pass — solo cambia el nombre de la BD
DB_DATABASE_KRAFTDO=kraftdo_bd
DB_DATABASE_ADILLE=kraftdo_adille
DB_DATABASE_EXTRACTORES=kraftdo_extractores

# Opcional: credenciales distintas por empresa (máxima separación)
# DB_USERNAME_ADILLE=adille_user
# DB_PASSWORD_ADILLE=adille_pass_seguro
# DB_USERNAME_EXTRACTORES=extractores_user
# DB_PASSWORD_EXTRACTORES=extractores_pass_seguro

# ─── Sesion 1: mejoras profesionales ───────────────────────────────────────────

# Sentry (monitoreo de errores) — opcional, si no usa email a EMAIL_CESAR
SENTRY_DSN=
APP_ENV=production

# Email del administrador (recibe alertas de errores y onboarding)
EMAIL_CESAR=hola@kraftdo.cl

# Cache TTL por defecto en segundos (5 minutos)
CACHE_TTL=300

# Retención de backups en días
BACKUP_RETENCION_DIAS=30

# MinIO (backups diarios)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=kraftdo
MINIO_ROOT_PASSWORD=

# ─── Sesion 2: DevOps ──────────────────────────────────────────────────────────
GRAFANA_PASS=kraftdo_admin
MEILI_MASTER_KEY=

# ─── Sesion 3: Features ────────────────────────────────────────────────────────
DEFAULT_LANG=es
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TELEGRAM_BOT_TOKEN=
REVERB_APP_ID=kraftdo
REVERB_APP_KEY=
REVERB_APP_SECRET=

# ─── Sesion 4: Seguridad avanzada ──────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRES_MIN=15
JWT_REFRESH_EXPIRES_DAYS=7
ENCRYPTION_KEY=
RATE_LIMIT_ANON=60
RATE_LIMIT_AUTH=600
RATE_LIMIT_ADMIN=3000
VAULT_PROVIDER=env
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=

# ─── Backup a Google Drive (opcional, adicional a MinIO) ──────────────────────
GOOGLE_CREDS_PATH=/app/creds.json
GDRIVE_FOLDER_ID=
