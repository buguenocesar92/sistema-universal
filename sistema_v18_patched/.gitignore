# KraftDo Sistema — .gitignore

# ── Secretos y configuración ────────────────────────────────────────────────
.env
*.env
creds.json
*_credentials.json
service_account*.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Laravel generado (no subir output — se genera con generator.py) ──────────
laravel_output*/
laravel_v*/
sistema_*/
mi-sistema*/

# ── n8n generado ─────────────────────────────────────────────────────────────
n8n_workflows/
n8n_final/
n8n_v*/

# ── Diff y migraciones generadas ─────────────────────────────────────────────
diff_migrations/
consolidado/

# ── Historial (snapshots locales, no compartir) ───────────────────────────────
historial/

# ── Temporales de uploads ────────────────────────────────────────────────────
/tmp/
uploads_temp/

# ── Excel de clientes (datos sensibles) ──────────────────────────────────────
# Descomentar si el Excel tiene datos reales de clientes
# *.xlsx
# *.xlsm
# *.xls

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ───────────────────────────────────────────────────────────────────
# Los volúmenes Docker son locales, no van al repo
mysql_data/
redis_data/
minio_data/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── ZIP de distribución (se regeneran) ───────────────────────────────────────
*.zip

# ── Test coverage ────────────────────────────────────────────────────────────
.coverage
htmlcov/
coverage.xml
